# Files and folders to exclude from the Vercel deployment.
# These are kept in git for reference but not shipped to the runtime.

# Bob conversation session logs — large JSON files used only for dev history.
bob_sessions/

# Local test fixtures — only used for offline analysis / regression testing.
TestCases/

# Tests and test helpers — never run on the deployed serverless function.
tests/

# Smoke-test CLI script for local debugging.
scripts/

# Internal docs.
BOB_DEVELOPMENT.md
docs/

# Leftover development artifacts.
tempCodeRunnerFile.js
test-api.js
accuracy-report.json
accuracy-report.raw.json
